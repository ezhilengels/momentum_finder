# ─── Sector Tracker V2 — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Telegram Bot
# 1. Talk to @BotFather on Telegram → /newbot → copy the token below
# 2. Start a chat with your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id (look for "id" inside "chat")
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Data download mode ────────────────────────────────────────────────────────
# BATCH_DOWNLOAD=true   → bulk yfinance (batch=30, fast ~5 min for 500 stocks)
# BATCH_DOWNLOAD=false  → per-ticker Stooq → jugaad → yfinance (slower but more
#                         resilient if yfinance is rate-limiting you)
BATCH_DOWNLOAD=true

# Optional: Simulation / debug overrides (used by config.py)
# SIMULATION_MODE=false
